    "version": "1.0.0",
    "label": "Logo Carousel",
    "category": "Content",
    "icon": "mdi:image-multiple-outline",
    "description": "Auto-scrolling infinite marquee of logos or images",
    "keywords": ["logo", "carousel", "marquee", "brand", "partner", "client", "scroll"],
    "contexts": ["page"],
    "supports": {
        "spacing": true,
