            { "src": "https://placehold.co/150x50/e2e8f0/64748b?text=Logo+3", "alt": "Logo 3", "link": "" },
            { "src": "https://placehold.co/150x50/e2e8f0/64748b?text=Logo+4", "alt": "Logo 4", "link": "" },
            { "src": "https://placehold.co/150x50/e2e8f0/64748b?text=Logo+5", "alt": "Logo 5", "link": "" },
            { "src": "https://placehold.co/150x50/e2e8f0/64748b?text=Logo+6", "alt": "Logo 6", "link": "" }
